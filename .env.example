# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 書籍情報API（どちらか一方）
RAKUTEN_APP_ID=
GOOGLE_BOOKS_API_KEY=

# Chrome 拡張機能連携
# - NEXT_PUBLIC_EXTENSION_ID: chrome://extensions で確認した拡張機能 ID
#   未設定の場合、Web アプリは拡張機能へのトークン送信をスキップする (no-op)
#   拡張機能 ID は公開鍵のハッシュから決定論的に算出されるため秘密情報ではない
NEXT_PUBLIC_EXTENSION_ID=

# - CRX_PUBLIC_KEY: 拡張機能の公開鍵 (dev ビルドで Extension ID を固定化するため)
#   `openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt -out key.pem` 等で生成後、
#   `openssl rsa -in key.pem -pubout -outform DER | base64 -w0` で base64 化した値を設定
#   開発者間で同じ ID を使うためローカル共有される運用になる (非秘密)
CRX_PUBLIC_KEY=
